# Auto-detect text files and normalize line endings to LF

* text=auto eol=lf


# Source code (always LF)

*.py      text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.toml    text eol=lf
*.cfg     text eol=lf
*.ini     text eol=lf
*.md      text eol=lf
*.rst     text eol=lf
*.txt     text eol=lf
*.json    text eol=lf
*.sh      text eol=lf
*.ps1     text eol=lf
Makefile  text eol=lf
*.csv     text eol=lf
*.tsv     text eol=lf


# Shell scripts (ensure executable in repo)

*.sh      text eol=lf
scripts/**/*.sh  text eol=lf


# Binary files (Git LFS — large model / data files)

# Model checkpoints
*.pt      filter=lfs diff=lfs merge=lfs -text
*.pth     filter=lfs diff=lfs merge=lfs -text
*.ckpt    filter=lfs diff=lfs merge=lfs -text
*.bin     filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.onnx    filter=lfs diff=lfs merge=lfs -text
*.h5      filter=lfs diff=lfs merge=lfs -text

# Large data files
*.csv.gz  filter=lfs diff=lfs merge=lfs -text
*.parquet filter=lfs diff=lfs merge=lfs -text
*.arrow   filter=lfs diff=lfs merge=lfs -text
*.feather filter=lfs diff=lfs merge=lfs -text
*.npy     filter=lfs diff=lfs merge=lfs -text
*.npz     filter=lfs diff=lfs merge=lfs -text
*.pickle  filter=lfs diff=lfs merge=lfs -text
*.pkl     filter=lfs diff=lfs merge=lfs -text

# Model formats
*.gguf    filter=lfs diff=lfs merge=lfs -text


# Images, video, audio

*.png     filter=lfs diff=lfs merge=lfs -text
*.jpg     filter=lfs diff=lfs merge=lfs -text
*.jpeg    filter=lfs diff=lfs merge=lfs -text
*.gif     filter=lfs diff=lfs merge=lfs -text
*.svg     text eol=lf
*.ico     filter=lfs diff=lfs merge=lfs -text
*.webp    filter=lfs diff=lfs merge=lfs -text
*.mp4     filter=lfs diff=lfs merge=lfs -text
*.wav     filter=lfs diff=lfs merge=lfs -text


# Archives

*.tar.gz  filter=lfs diff=lfs merge=lfs -text
*.tgz     filter=lfs diff=lfs merge=lfs -text
*.zip     filter=lfs diff=lfs merge=lfs -text


# Linguist overrides (GitHub stats)

uv.lock                               linguist-generated=true
uv.lock                               linguist-vendored=true
.*.yml                                linguist-detectable=false
*.lock                                linguist-generated=true
scripts/download_data.py              linguist-vendored=true

# Data directories
data/**                               linguist-generated=true
outputs/**                            linguist-generated=true

# CI generated
coverage.xml                          linguist-generated=true
